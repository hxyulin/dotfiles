[user]
  name = hxyulin
  email = {{ .email }}
{{- if .isDarwin }}
  signingkey = ~/.ssh/id_ed25519.pub

[gpg]
  format = ssh

[commit]
  gpgsign = true

[tag]
  gpgsign = true
{{- end }}

[init]
  defaultBranch = main

[core]
  excludesfile = ~/.gitignore_global
  editor = nvim
  pager = delta

[interactive]
  diffFilter = delta --color-only

[delta]
  navigate = true
  dark = true
  line-numbers = true

[merge]
  conflictstyle = zdiff3

[diff]
  colorMoved = default

[pull]
  rebase = true

[push]
  autoSetupRemote = true
