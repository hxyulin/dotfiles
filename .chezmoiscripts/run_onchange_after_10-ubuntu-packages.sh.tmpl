{{- if .isUbuntu -}}
#!/bin/bash
# apt-packages hash: {{ include "dot_config/apt-packages.txt" | sha256sum }}
set -euo pipefail
echo "Installing apt packages..."

# Add eza repository
if [ ! -f /etc/apt/keyrings/gierens.gpg ]; then
  sudo mkdir -p /etc/apt/keyrings
  wget -qO- https://raw.githubusercontent.com/eza-community/eza/main/deb.asc | sudo gpg --dearmor -o /etc/apt/keyrings/gierens.gpg
  echo "deb [signed-by=/etc/apt/keyrings/gierens.gpg] http://deb.gierens.de stable main" | sudo tee /etc/apt/sources.list.d/gierens.list
  sudo chmod 644 /etc/apt/keyrings/gierens.gpg /etc/apt/sources.list.d/gierens.list
fi

sudo apt-get update
grep -v '^#' ~/.config/apt-packages.txt | grep -v '^\s*$' | xargs sudo apt-get install -y

# Install eza (from added repo)
sudo apt-get install -y eza

# Shim Debian/Ubuntu binary names to the expected commands (~/.local/bin is on PATH).
# apt ships fd-find as `fdfind` and bat as `batcat`.
mkdir -p ~/.local/bin
if [ ! -e ~/.local/bin/fd ] && command -v fdfind &>/dev/null; then
  ln -s "$(command -v fdfind)" ~/.local/bin/fd
fi
if [ ! -e ~/.local/bin/bat ] && command -v batcat &>/dev/null; then
  ln -s "$(command -v batcat)" ~/.local/bin/bat
fi
{{- end }}
