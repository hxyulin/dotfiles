# .bash_profile — login bash shells.
#
# All env/PATH/tool setup now lives in .bashrc (above its interactive
# guard) so it loads for EVERY bash process. BASH_ENV makes
# non-interactive bash (AI agents, scripts: `bash -c ...`) read it too.
export BASH_ENV="$HOME/.bashrc"

# Source bashrc (env + interactive setup for this login shell).
[[ -f ~/.bashrc ]] && . ~/.bashrc
