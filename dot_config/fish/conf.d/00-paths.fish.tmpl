# Cargo
if test -d "$HOME/.cargo/bin"
    fish_add_path "$HOME/.cargo/bin"
end

# Bob (neovim version manager)
if test -d "$HOME/.local/share/bob/nvim-bin"
    fish_add_path "$HOME/.local/share/bob/nvim-bin"
end

# fnm (Fast Node Manager)
if test -d "$HOME/.local/share/fnm"
    fish_add_path "$HOME/.local/share/fnm"
end

# Local binaries
fish_add_path "$HOME/.local/bin"

# Editor
set -gx EDITOR nvim

# Ripgrep config
set -gx RIPGREP_CONFIG_PATH "$HOME/.config/ripgrep/config"
{{- if .isDarwin }}

# Vulkan SDK (macOS / MoltenVK)
if test -d "$HOME/VulkanSDK/{{ .vulkanVersion }}/macOS"
    set -gx VULKAN_SDK "$HOME/VulkanSDK/{{ .vulkanVersion }}/macOS"
    fish_add_path "$VULKAN_SDK/bin"
    set -gx DYLD_LIBRARY_PATH "$VULKAN_SDK/lib" $DYLD_LIBRARY_PATH
    set -gx VK_ADD_LAYER_PATH "$VULKAN_SDK/share/vulkan/explicit_layer.d"
    set -gx VK_ICD_FILENAMES "$VULKAN_SDK/share/vulkan/icd.d/MoltenVK_icd.json"
    set -gx VK_DRIVER_FILES "$VULKAN_SDK/share/vulkan/icd.d/MoltenVK_icd.json"
    set -gx PKG_CONFIG_PATH "$VULKAN_SDK/lib/pkgconfig" $PKG_CONFIG_PATH
end

# Homebrew (macOS)
if test -x /opt/homebrew/bin/brew
    eval (/opt/homebrew/bin/brew shellenv)
end
{{- end }}
{{- if .isUbuntu }}

# Linuxbrew (optional)
if test -x /home/linuxbrew/.linuxbrew/bin/brew
    eval (/home/linuxbrew/.linuxbrew/bin/brew shellenv)
end
{{- end }}
