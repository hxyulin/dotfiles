# ~/.config/shell/env.sh — shared environment for bash & zsh.
#
# Sourced from .zshenv (all zsh shells) and .bashrc (all bash shells,
# including non-interactive agents/scripts via BASH_ENV). Single source of
# truth for env/PATH so the two POSIX shells never drift. Keep it
# bash+zsh compatible — no fish syntax. fish keeps its own copy at
# ~/.config/fish/conf.d/00-paths.fish (different syntax, can't share).
#
# Safe to source more than once: zsh dedupes PATH via `typeset -U path`
# (set in .zshenv) and every edit below is idempotent, so .zprofile can
# re-source this after macOS path_helper reorders PATH on login shells.

# Editor
export EDITOR=nvim

# Ripgrep config
export RIPGREP_CONFIG_PATH="$HOME/.config/ripgrep/config"

# Cargo
[ -f "$HOME/.cargo/env" ] && . "$HOME/.cargo/env"

# Bob (neovim version manager)
[ -d "$HOME/.local/share/bob/nvim-bin" ] && export PATH="$HOME/.local/share/bob/nvim-bin:$PATH"

# fnm (Fast Node Manager)
export PATH="$HOME/.local/share/fnm:$PATH"

# Local binaries (pipx, etc.)
export PATH="$HOME/.local/bin:$PATH"

# Homebrew
[ -x /opt/homebrew/bin/brew ] && eval "$(/opt/homebrew/bin/brew shellenv)"
[ -x /home/linuxbrew/.linuxbrew/bin/brew ] && eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
{{- if .isDarwin }}

# Vulkan SDK (macOS / MoltenVK) — version pinned in .chezmoidata.toml
if [ -d "$HOME/VulkanSDK/{{ .vulkanVersion }}/macOS" ]; then
  export VULKAN_SDK="$HOME/VulkanSDK/{{ .vulkanVersion }}/macOS"
  export PATH="$VULKAN_SDK/bin:$PATH"
  export DYLD_LIBRARY_PATH="$VULKAN_SDK/lib:${DYLD_LIBRARY_PATH:-}"
  export VK_ADD_LAYER_PATH="$VULKAN_SDK/share/vulkan/explicit_layer.d"
  export VK_ICD_FILENAMES="$VULKAN_SDK/share/vulkan/icd.d/MoltenVK_icd.json"
  export VK_DRIVER_FILES="$VULKAN_SDK/share/vulkan/icd.d/MoltenVK_icd.json"
  export PKG_CONFIG_PATH="$VULKAN_SDK/lib/pkgconfig:${PKG_CONFIG_PATH:-}"
fi
{{- end }}
