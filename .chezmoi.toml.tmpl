{{- $profile := promptChoiceOnce . "profile" "Machine profile" (list "macbook" "arch" "ubuntu") -}}
{{- $email := promptStringOnce . "email" "Git email address" -}}

{{- /* Derived settings based on profile */ -}}
{{- $isDarwin := eq $profile "macbook" -}}
{{- $isArch := eq $profile "arch" -}}
{{- $isUbuntu := eq $profile "ubuntu" -}}
{{- $isLinux := or $isArch $isUbuntu -}}

{{- /* Font settings */ -}}
{{- $fontFamily := "JetBrainsMono Nerd Font" -}}
{{- if $isDarwin -}}
{{-   $fontFamily = "JetbrainsMono NFM" -}}
{{- end -}}
{{- $fontSize := 12 -}}
{{- if $isArch -}}
{{-   $fontSize = 10 -}}
{{- end -}}

[data]
  profile = {{ $profile | quote }}
  email = {{ $email | quote }}
  fontSize = {{ $fontSize }}
  fontFamily = {{ $fontFamily | quote }}

  # Platform flags
  isDarwin = {{ $isDarwin }}
  isArch = {{ $isArch }}
  isUbuntu = {{ $isUbuntu }}
  isLinux = {{ $isLinux }}

  # Feature flags
  nixDarwin = {{ $isDarwin }}
  gitSigning = {{ $isDarwin }}
  hyprland = {{ $isArch }}
  sway = {{ $isArch }}

