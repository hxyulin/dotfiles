# .zshenv — sourced by EVERY zsh shell (interactive, login, scripts).

# Dedupe PATH, keeping the first occurrence, so repeated prepends across
# .zshenv / .zprofile re-sourcing never accumulate duplicate entries.
typeset -U path PATH

# Shared env/PATH for bash & zsh (single source of truth).
[ -f "$HOME/.config/shell/env.sh" ] && . "$HOME/.config/shell/env.sh"
